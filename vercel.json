{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "rootDirectory": "frontend",
      "framework": "vite"
    },
    "api": {
      "rootDirectory": ".",
      "framework": null
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
