{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --port 5000 --host",
    "dev:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-full.ps1",
    "dev:api": "python backend/main.py",
    "dev:api:always": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backend-always.ps1",
    "train:pg": "python scripts/train_pg.py --xlsx D23V7.xlsx --text mnop02.txt mnop03.txt",
    "train:qa": "python scripts/generate_bulk_qa.py",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}

